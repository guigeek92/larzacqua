# Configuration des clés API pour SimuWatter
# Dupliquez ce fichier en .env et remplissez vos vraies clés

# Clé API Groq (pour les analyses IA)
# Obtenez votre clé à : https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Token Hugging Face (optionnel, pour certains modèles)
# Obtenez votre token à : https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here
